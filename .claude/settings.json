{
  "mcpServers": {
    "umu-teacher": {
      "command": "python",
      "args": ["-m", "umu_sdk.adapters.mcp.teacher"],
      "env": {
        "UMU_TEACHER_USERNAME": "${UMU_TEACHER_USERNAME}",
        "UMU_TEACHER_PASSWORD": "${UMU_TEACHER_PASSWORD}",
        "UMU_BASE_URL": "${UMU_BASE_URL:-https://www.umu.cn}",
        "MCP_LOG_LEVEL": "${MCP_LOG_LEVEL:-INFO}"
      }
    },
    "umu-student": {
      "command": "python",
      "args": ["-m", "umu_sdk.adapters.mcp.student"],
      "env": {
        "UMU_STUDENT_USERNAME": "${UMU_STUDENT_USERNAME}",
        "UMU_STUDENT_PASSWORD": "${UMU_STUDENT_PASSWORD}",
        "UMU_BASE_URL": "${UMU_BASE_URL:-https://www.umu.cn}",
        "MCP_LOG_LEVEL": "${MCP_LOG_LEVEL:-INFO}"
      }
    },
    "umu-admin": {
      "command": "python",
      "args": ["-m", "umu_sdk.adapters.mcp.admin"],
      "env": {
        "UMU_ADMIN_USERNAME": "${UMU_ADMIN_USERNAME}",
        "UMU_ADMIN_PASSWORD": "${UMU_ADMIN_PASSWORD}",
        "UMU_BASE_URL": "${UMU_BASE_URL:-https://www.umu.cn}",
        "MCP_LOG_LEVEL": "${MCP_LOG_LEVEL:-INFO}"
      }
    }
  }
}
